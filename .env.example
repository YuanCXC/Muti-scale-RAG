# RAG 系统环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== LLM API 配置 ====================

# OpenAI 兼容 API (支持 OpenAI, DeepSeek, 通义千问等)
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic API (可选)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama 本地模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# ==================== LLM 参数 ====================

# LLM 模型名称
LLM_MODEL=gpt-3.5-turbo

# 温度参数 (0.0 - 2.0)
LLM_TEMPERATURE=0.7

# 最大 token 数
LLM_MAX_TOKENS=4096

# ==================== 嵌入模型配置 ====================

# 嵌入模式: api, local, bge, auto
# - api: 使用 API 服务 (OpenAI, 通义千问等)
# - local: 使用 sentence-transformers 本地模型
# - bge: 使用 FlagEmbedding (BGE 系列模型)
# - auto: 根据配置自动选择
EMBEDDING_MODE=auto

# 嵌入模型名称
# API 模式示例:
#   - text-embedding-ada-002 (OpenAI)
#   - text-embedding-v3 (通义千问)
# 本地模式示例:
#   - BAAI/bge-large-zh-v1.5 (中文，推荐)
#   - BAAI/bge-m3 (多语言)
#   - sentence-transformers/all-MiniLM-L6-v2 (英文，轻量)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# 本地模型设备: cuda, cpu, auto
EMBEDDING_DEVICE=auto

# 是否使用半精度 (仅 BGE 模型，可节省显存)
EMBEDDING_USE_FP16=true

# ==================== 数据库配置 ====================

# Neo4j 图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# PostgreSQL (可选)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Redis (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 向量数据库配置 ====================

# FAISS 索引存储路径
FAISS_INDEX_PATH=./data/faiss_index

# Milvus (可选)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_collection

# ==================== 检索参数配置 ====================

# 检索数量
TOP_K=10

# 重排序后数量
RERANK_TOP_K=5

# 向量维度 (OpenAI: 1536, DeepSeek: 1024, BGE: 1024)
VECTOR_DIM=1024

# 相似度阈值
SIMILARITY_THRESHOLD=0.7

# ==================== 文本处理配置 ====================

# 分块大小
CHUNK_SIZE=512

# 分块重叠
CHUNK_OVERLAP=50

# ==================== 重排序配置 ====================

# 重排序模型
RERANK_MODEL=BAAI/bge-reranker-large

# ==================== 日志配置 ====================

LOG_LEVEL=INFO
LOG_FILE=logs/rag_system.log

# ==================== 应用配置 ====================

# 环境: development, production, testing
ENVIRONMENT=development

# 调试模式
DEBUG=true
